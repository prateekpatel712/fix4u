# Fix4U — environment variables (Tech Spec §6, extended).
# Copy to `.env.local` for dev; set the same keys in your host (Vercel/Cloudflare) for prod.
# NEVER commit real secrets. Only NEXT_PUBLIC_* vars are exposed to the browser.

# ---- Site ----
NEXT_PUBLIC_SITE_URL=https://fix4u.example.com

# ---- Sanity CMS ----
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01
# Read token only needed for drafts/preview or private datasets; public datasets read without it.
SANITY_API_READ_TOKEN=
# Secret that protects the /api/revalidate webhook (set the same value in the Sanity webhook).
SANITY_REVALIDATE_SECRET=

# ---- Email (Resend) ----
RESEND_API_KEY=
# Verified sender, e.g. "Fix4U <hello@fix4u.com>"
EMAIL_FROM="Fix4U <hello@fix4u.example.com>"
# Where founder notifications (new lead, audit request) are sent.
CONTACT_TO_EMAIL=prateek@fix4u.example.com

# ---- Spam protection (Cloudflare Turnstile) ----
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ---- CRM (HubSpot) ----
HUBSPOT_TOKEN=

# ---- Booking (Cal.com) ----
# Public booking handle, e.g. "fix4u/discovery"
NEXT_PUBLIC_CALCOM_LINK=fix4u/discovery
CALCOM_WEBHOOK_SECRET=

# ---- AI chatbot (Google Gemini) ----
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Model id — default is Gemini 2.5 Flash (fast + cheap, ideal for high-volume chat).
# Use gemini-2.5-pro for higher quality at more cost/latency.
CHAT_MODEL=gemini-2.5-flash

# ---- Analytics ----
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_CLARITY_ID=

# ---- WhatsApp click-to-chat ----
# International format, digits only, no '+' (e.g. 919876543210).
NEXT_PUBLIC_WHATSAPP_NUMBER=

# ---- WhatsApp AI agent (Meta Cloud API) ----
# Webhook handshake token — you invent this string, paste the SAME value into Meta's webhook config.
WHATSAPP_VERIFY_TOKEN=
# Permanent access token (System User token) from Meta.
WHATSAPP_TOKEN=
# Phone Number ID from the WhatsApp > API Setup screen.
WHATSAPP_PHONE_NUMBER_ID=
# WhatsApp Business Account ID (WABA).
WHATSAPP_BUSINESS_ACCOUNT_ID=
# App secret (Meta app > Settings > Basic) — verifies inbound webhook signatures.
WHATSAPP_APP_SECRET=
# Optional: Graph API version (default v21.0).
WHATSAPP_GRAPH_VERSION=v21.0
